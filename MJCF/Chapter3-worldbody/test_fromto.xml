<!-- fromto属性演示: 用两点定义几何体的位置、长度和方向 -->
<mujoco model="fromto_demo">
    <compiler angle="radian"/>
    <option timestep="0.002" gravity="0 0 -9.81"/>

    <visual>
        <global realtime="1"/>
        <quality shadowsize="1024"/>
        <headlight diffuse="1 1 1" specular="0.5 0.5 0.5" active="1"/>
    </visual>

    <asset>
        <texture name="grid" type="2d" builtin="checker" width="512" height="512"
                 rgb1=".2 .2 .2" rgb2=".8 .8 .8"/>
        <material name="grid" texture="grid"/>
    </asset>

    <!--
    fromto="x1 y1 z1  x2 y2 z2"
    几何体的Z轴正方向 = point2 → point1
    几何体的长度 = 两点之间的距离
    同时定义了: 位置、长度、旋转
    -->
    <worldbody>
        <geom name="floor" type="plane" size="20 20 .01" material="grid" condim="3"/>

        <!-- 垂直向上的胶囊体 -->
        <body pos="-4 0 .2">
            <geom type="capsule" size="0.08" fromto="0 0 0  0 0 1"
                  rgba=".9 .2 .2 1"/>
        </body>

        <!-- 45度倾斜的胶囊体 -->
        <body pos="-2 0 .2">
            <geom type="capsule" size="0.08" fromto="0 0 0  0.5 0 0.5"
                  rgba=".2 .9 .2 1"/>
        </body>

        <!-- 水平放置的胶囊体 -->
        <body pos="0 0 .2">
            <geom type="capsule" size="0.08" fromto="0 0 0  0.8 0 0"
                  rgba=".2 .2 .9 1"/>
        </body>

        <!-- 用fromto做圆柱体连接两个点 -->
        <body pos="2 0 .2">
            <geom type="cylinder" size="0.06" fromto="0 0 0  0.3 0.5 0.6"
                  rgba=".9 .7 .2 1"/>
        </body>

        <!-- 对比: 用pos+size+euler方式实现同样效果更繁琐 -->
        <!-- fromto一个属性 = pos + euler + size三个属性 -->

        <!-- 实际应用: 用fromto构建简单的机械臂结构 -->
        <body pos="0 4 0.5">
            <freejoint/>
            <geom type="sphere" size="0.1" rgba=".7 .7 .7 1"/>
            <!-- 上臂 -->
            <body pos="0 0 0">
                <geom type="capsule" size="0.06" fromto="0 0 0  0.5 0 0"
                      rgba=".9 .2 .2 1"/>
                <!-- 前臂 -->
                <body pos="0.5 0 0">
                    <geom type="capsule" size="0.05" fromto="0 0 0  0.4 0 0"
                          rgba=".2 .2 .9 1"/>
                    <!-- 手 -->
                    <body pos="0.4 0 0">
                        <geom type="box" size="0.06 0.03 0.08" rgba=".2 .8 .2 1"/>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>
</mujoco>
