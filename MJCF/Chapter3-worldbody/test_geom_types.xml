<!-- 所有8种geom类型演示 -->
<mujoco model="geom_types">
    <compiler angle="radian"/>
    <option timestep="0.002" gravity="0 0 -9.81"/>

    <visual>
        <global realtime="1"/>
        <quality shadowsize="1024"/>
        <headlight diffuse="1 1 1" specular="0.5 0.5 0.5" active="1"/>
    </visual>

    <asset>
        <texture name="grid" type="2d" builtin="checker" width="512" height="512"
                 rgb1=".2 .2 .2" rgb2=".8 .8 .8" mark="cross" markrgb=".5 .5 .5"/>
        <material name="grid" texture="grid" reflectance="0.2"/>
        <material name="red" rgba=".8 .1 .1 1"/>
        <material name="green" rgba=".1 .7 .2 1"/>
        <material name="blue" rgba=".1 .3 .9 1"/>
        <material name="yellow" rgba=".9 .8 .1 1"/>
        <material name="purple" rgba=".7 .1 .8 1"/>
        <material name="cyan" rgba=".1 .8 .8 1"/>
        <material name="orange" rgba=".9 .5 .1 1"/>
        <mesh name="tetrahedron" vertex="0 0 0 1 0 0 0 1 0 0 0 1"/>
    </asset>

    <worldbody>
        <geom name="floor" type="plane" size="20 20 .01" material="grid" condim="3"/>

        <!-- plane 平面 —— 注意type="plane"的geom永远是静态的 -->
        <body pos="-4 3 .3">
            <geom type="plane" size=".5 .5 .05" material="red"/>
        </body>

        <!-- sphere 球体 -->
        <body pos="-2.5 3 .3">
            <freejoint/>
            <geom type="sphere" size="0.3" material="green"/>
        </body>

        <!-- capsule 胶囊体 -->
        <body pos="-1 3 .3">
            <freejoint/>
            <geom type="capsule" size="0.15 0.4" material="blue"/>
        </body>

        <!-- cylinder 圆柱体 -->
        <body pos="0.5 3 .3">
            <freejoint/>
            <geom type="cylinder" size="0.15 0.4" material="yellow"/>
        </body>

        <!-- box 立方体 -->
        <body pos="2 3 .3">
            <freejoint/>
            <geom type="box" size="0.25 0.25 0.25" material="purple"/>
        </body>

        <!-- ellipsoid 椭球体 (三轴不等) -->
        <body pos="3.5 3 .3">
            <freejoint/>
            <geom type="ellipsoid" size="0.3 0.2 0.4" material="cyan"/>
        </body>

        <!-- mesh 网格（四面体） -->
        <body pos="5 3 .3">
            <freejoint/>
            <geom type="mesh" mesh="tetrahedron" rgba=".9 .5 .1 1"/>
        </body>

        <!-- hfield 高度场 —— 暂用静态box示意位置，真正hfield需要高度图文件 -->
        <body pos="-4 -1 .1">
            <geom type="box" size="0.3 0.3 0.02" rgba=".5 .5 .5 1"/>
        </body>

        <!-- 平面上的标签球用来对比大小 -->
        <body pos="-4 3 1.2">
            <site type="sphere" size="0.04" rgba="1 1 1 0.5"/>
        </body>
        <body pos="-2.5 3 1.2">
            <site type="sphere" size="0.04" rgba="1 1 1 0.5"/>
        </body>
        <body pos="-1 3 1.2">
            <site type="sphere" size="0.04" rgba="1 1 1 0.5"/>
        </body>
        <body pos="0.5 3 1.2">
            <site type="sphere" size="0.04" rgba="1 1 1 0.5"/>
        </body>
        <body pos="2 3 1.2">
            <site type="sphere" size="0.04" rgba="1 1 1 0.5"/>
        </body>
        <body pos="3.5 3 1.2">
            <site type="sphere" size="0.04" rgba="1 1 1 0.5"/>
        </body>
        <body pos="5 3 1.2">
            <site type="sphere" size="0.04" rgba="1 1 1 0.5"/>
        </body>
    </worldbody>
</mujoco>
