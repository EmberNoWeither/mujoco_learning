<!-- mass vs density 和 shellinertia 演示 -->
<mujoco model="mass_density">
    <compiler angle="radian"/>
    <option timestep="0.002" gravity="0 0 -9.81"/>

    <visual>
        <global realtime="1"/>
        <quality shadowsize="1024"/>
        <headlight diffuse="1 1 1" specular="0.5 0.5 0.5" active="1"/>
    </visual>

    <asset>
        <texture name="grid" type="2d" builtin="checker" width="512" height="512"
                 rgb1=".2 .2 .2" rgb2=".8 .8 .8"/>
        <material name="grid" texture="grid"/>
    </asset>

    <!--
    mass 和 density 二选一:
    - mass: 直接指定质量(kg)，不论体积大小
    - density: 指定密度(kg/m³)，MuJoCo根据几何体体积自动计算质量
    - shellinertia: true=质量集中在边缘(中空感)，false=均匀密度
    -->
    <worldbody>
        <geom name="floor" type="plane" size="20 20 .01" material="grid" condim="3"/>

        <!-- 相同大小，不同mass: 越重落地越快 -->
        <body pos="-3 3 1.5">
            <freejoint/>
            <geom type="sphere" size="0.2" rgba=".9 .3 .3 1" mass="0.1"/>
        </body>
        <body pos="-2.3 3 1.5">
            <freejoint/>
            <geom type="sphere" size="0.2" rgba=".9 .5 .3 1" mass="1"/>
        </body>
        <body pos="-1.6 3 1.5">
            <freejoint/>
            <geom type="sphere" size="0.2" rgba=".9 .7 .3 1" mass="10"/>
        </body>

        <!-- 相同density，不同体积: 自然质量不同 -->
        <body pos="-5 3 1.5">
            <freejoint/>
            <geom type="sphere" size="0.1" rgba=".3 .9 .3 1" density="1000"/>
        </body>
        <body pos="-5.3 3 1.5">
            <freejoint/>
            <geom type="sphere" size="0.2" rgba=".3 .7 .8 1" density="1000"/>
        </body>
        <body pos="-5.7 3 1.5">
            <freejoint/>
            <geom type="sphere" size="0.3" rgba=".3 .5 1 1" density="1000"/>
        </body>

        <!-- shellinertia对比: 相同质量和大小的空心球 vs 实心球 -->
        <body pos="1 3 1.5">
            <freejoint/>
            <!-- shellinertia=true: 质量集中在球壳表面，转动惯量大，转得慢 -->
            <geom type="sphere" size="0.25" rgba=".9 .5 .1 1"
                  mass="1" shellinertia="true"/>
        </body>
        <body pos="2 3 1.5">
            <freejoint/>
            <!-- shellinertia=false(默认): 均匀密度，转动惯量小，转得快 -->
            <geom type="sphere" size="0.25" rgba=".1 .5 .9 1"
                  mass="1" shellinertia="false"/>
        </body>

        <!-- 斜面用于观察滚动加速度差异 -->
        <body pos="1.5 0.5 0" euler="0 -.4 0">
            <geom type="box" size="1.5 .3 .1" rgba=".4 .4 .4 1"/>
        </body>

        <!-- buoyancy演示: 不同密度的物体会表现出不同的浮力效果 -->
        <!-- (需配合option中的density和viscosity参数) -->
    </worldbody>
</mujoco>
