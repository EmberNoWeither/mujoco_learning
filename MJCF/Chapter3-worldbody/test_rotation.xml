<!-- 旋转表示方式演示: euler, quat, axisangle, zaxis, xyaxes -->
<mujoco model="rotation_demo">
    <compiler angle="radian"/>
    <option timestep="0.002" gravity="0 0 -9.81"/>

    <visual>
        <global realtime="1"/>
        <quality shadowsize="1024"/>
        <headlight diffuse="1 1 1" specular="0.5 0.5 0.5" active="1"/>
    </visual>

    <asset>
        <texture name="grid" type="2d" builtin="checker" width="512" height="512"
                 rgb1=".2 .2 .2" rgb2=".8 .8 .8"/>
        <material name="grid" texture="grid"/>
    </asset>

    <worldbody>
        <geom name="floor" type="plane" size="20 20 .01" material="grid" condim="3"/>

        <!-- 参考: 无旋转的原始方向 -->
        <body pos="-5 3 .6">
            <geom type="box" size="0.3 0.15 0.08" rgba=".5 .5 .5 1"/>
        </body>

        <!-- euler: 绕X轴45度, Y轴0度, Z轴0度 (单位: rad) -->
        <body pos="-3 3 .6" euler="0.785 0 0">
            <geom type="box" size="0.3 0.15 0.08" rgba=".9 .2 .2 1"/>
        </body>

        <!-- quat: 绕(0,0,1)轴旋转45度的四元数 (wxyz顺序!) -->
        <!-- cos(22.5°)=0.924, sin(22.5°)*0=0, sin(22.5°)*0=0, sin(22.5°)*1=0.383 -->
        <body pos="-1 3 .6" quat="0.924 0 0 0.383">
            <geom type="box" size="0.3 0.15 0.08" rgba=".2 .9 .2 1"/>
        </body>

        <!-- axisangle: 绕(1,0,0)轴旋转45度 -->
        <body pos="1 3 .6" axisangle="1 0 0 0.785">
            <geom type="box" size="0.3 0.15 0.08" rgba=".2 .2 .9 1"/>
        </body>

        <!-- zaxis: 指定Z轴指向(0,0.5,0.5)方向 -->
        <body pos="3 3 .6" zaxis="0 0.707 0.707">
            <geom type="box" size="0.3 0.15 0.08" rgba=".9 .7 .2 1"/>
        </body>

        <!-- xyaxes: 同时指定X轴和Y轴方向 -->
        <body pos="5 3 .6" xyaxes="0.707 0.707 0  -0.707 0.707 0">
            <geom type="box" size="0.3 0.15 0.08" rgba=".7 .2 .9 1"/>
        </body>

        <!-- 动态演示: 用euler做不同旋转量的box -->
        <body pos="-3 -1 .6" euler="0 0.785 0">
            <geom type="box" size="0.3 0.15 0.08" rgba=".9 .4 .4 1"/>
        </body>
        <body pos="-1 -1 .6" euler="0 0 -0.785">
            <geom type="box" size="0.3 0.15 0.08" rgba=".4 .9 .4 1"/>
        </body>
        <body pos="1 -1 .6" euler="0.4 0.6 0.2">
            <geom type="box" size="0.3 0.15 0.08" rgba=".4 .4 .9 1"/>
        </body>
    </worldbody>
</mujoco>
