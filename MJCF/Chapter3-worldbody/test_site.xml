<!-- site vs geom 对比演示 -->
<mujoco model="site_demo">
    <compiler angle="radian"/>
    <option timestep="0.002" gravity="0 0 -9.81"/>

    <visual>
        <global realtime="1"/>
        <quality shadowsize="1024"/>
        <headlight diffuse="1 1 1" specular="0.5 0.5 0.5" active="1"/>
    </visual>

    <asset>
        <texture name="grid" type="2d" builtin="checker" width="512" height="512"
                 rgb1=".2 .2 .2" rgb2=".8 .8 .8"/>
        <material name="grid" texture="grid"/>
    </asset>

    <worldbody>
        <geom name="floor" type="plane" size="20 20 .01" material="grid" condim="3"/>

        <!-- site vs geom 对比:
             site = 轻量版geom，无质量不碰撞，仅用于标记/传感器安装
             geom = 有质量有碰撞的物理体 -->

        <!-- 场景1: 带有site标记的球体（site随body运动，但不影响物理） -->
        <body pos="-3 3 1">
            <freejoint/>
            <geom type="sphere" size="0.2" rgba=".9 .2 .2 1"/>
            <!-- site标记球体的"顶部"和"前部" -->
            <site type="sphere" size="0.04" rgba="0 1 0 1" pos="0 0 0.25"/>
            <site type="sphere" size="0.04" rgba="0 0 1 1" pos="0.25 0 0"/>
        </body>

        <!-- 场景2: 纯site排布（无geom，仅可视化） -->
        <body pos="-1 3 0.5">
            <site type="box" size="0.15 0.15 0.15" rgba=".9 .7 .1 .6"/>
            <site type="sphere" size="0.1" rgba=".9 .3 .1 .6" pos="0 0 0.2"/>
            <site type="cylinder" size="0.05 0.2" rgba=".9 .1 .1 .6" pos="0 0 0.4"/>
        </body>

        <!-- 场景3: 同样形状的geom vs site并排对比 -->
        <!-- geom: 会掉落到地面 -->
        <body pos="1.5 3 1">
            <freejoint/>
            <geom type="box" size="0.15 0.15 0.15" rgba=".2 .8 .2 1" mass="0.1"/>
        </body>

        <!-- geom+site混合: site用于标记碰撞体的关键点 -->
        <body pos="3.5 3 1">
            <freejoint/>
            <geom type="capsule" size="0.1 0.25" rgba=".3 .3 .9 1"/>
            <!-- 标记两端 -->
            <site type="sphere" size="0.04" rgba="1 .8 0 1" pos="0 0 0.25"/>
            <site type="sphere" size="0.04" rgba="1 .8 0 1" pos="0 0 -0.25"/>
            <!-- 标记中心 -->
            <site type="sphere" size="0.03" rgba="1 0 0 1" pos="0 0 0"/>
        </body>
    </worldbody>
</mujoco>
