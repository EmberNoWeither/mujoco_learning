<!-- 关节动力学参数: stiffness, damping, frictionloss, armature -->
<mujoco model="joint_dynamics">
    <compiler angle="radian" autolimits="true"/>
    <option timestep="0.002" gravity="0 0 -9.81"/>

    <visual>
        <global realtime="1"/>
        <quality shadowsize="1024"/>
        <headlight diffuse="1 1 1" specular="0.5 0.5 0.5" active="1"/>
    </visual>

    <asset>
        <texture name="grid" type="2d" builtin="checker" width="512" height="512"
                 rgb1=".15 .15 .15" rgb2=".7 .7 .7"/>
        <material name="grid" texture="grid"/>
    </asset>

    <worldbody>
        <geom name="floor" type="plane" size="20 20 .01" material="grid" condim="3"/>

        <!-- stiffness对比: 不同弹簧刚度的hinge关节 -->
        <body pos="-4 3 0">
            <geom type="cylinder" size="0.04 0.2" rgba=".5 .5 .5 1"/>
            <body pos="0 0 0.2">
                <joint type="hinge" axis="0 1 0" stiffness="0" damping="0.005"/>
                <geom type="capsule" size="0.03 0.25" rgba=".9 .3 .3 1"/>
            </body>
        </body>
        <body pos="-3 3 0">
            <geom type="cylinder" size="0.04 0.2" rgba=".5 .5 .5 1"/>
            <body pos="0 0 0.2">
                <joint type="hinge" axis="0 1 0" stiffness="0.5" damping="0.005"/>
                <geom type="capsule" size="0.03 0.25" rgba=".9 .5 .3 1"/>
            </body>
        </body>
        <body pos="-2 3 0">
            <geom type="cylinder" size="0.04 0.2" rgba=".5 .5 .5 1"/>
            <body pos="0 0 0.2">
                <joint type="hinge" axis="0 1 0" stiffness="2.0" damping="0.005"/>
                <geom type="capsule" size="0.03 0.25" rgba=".9 .7 .3 1"/>
            </body>
        </body>
        <body pos="-1 3 0">
            <geom type="cylinder" size="0.04 0.2" rgba=".5 .5 .5 1"/>
            <body pos="0 0 0.2">
                <joint type="hinge" axis="0 1 0" stiffness="10" damping="0.01"/>
                <geom type="capsule" size="0.03 0.25" rgba=".8 .2 .2 1"/>
            </body>
        </body>

        <!-- 标签: stiffness 0 / 0.5 / 2 / 10 -->
        <site pos="-4 3 0.7" type="sphere" size="0.03" rgba="1 1 1 .5"/>
        <site pos="-3 3 0.7" type="sphere" size="0.03" rgba="1 1 1 .5"/>
        <site pos="-2 3 0.7" type="sphere" size="0.03" rgba="1 1 1 .5"/>
        <site pos="-1 3 0.7" type="sphere" size="0.03" rgba="1 1 1 .5"/>

        <!-- damping对比: 不同阻尼的hinge关节（都设stiffness=2让它们弹回） -->
        <body pos="1 3 0">
            <geom type="cylinder" size="0.04 0.2" rgba=".5 .5 .5 1"/>
            <body pos="0 0 0.2">
                <joint type="hinge" axis="0 1 0" stiffness="2" damping="0.001"/>
                <geom type="capsule" size="0.03 0.25" rgba=".3 .3 .9 1"/>
            </body>
        </body>
        <body pos="2 3 0">
            <geom type="cylinder" size="0.04 0.2" rgba=".5 .5 .5 1"/>
            <body pos="0 0 0.2">
                <joint type="hinge" axis="0 1 0" stiffness="2" damping="0.02"/>
                <geom type="capsule" size="0.03 0.25" rgba=".3 .5 .9 1"/>
            </body>
        </body>
        <body pos="3 3 0">
            <geom type="cylinder" size="0.04 0.2" rgba=".5 .5 .5 1"/>
            <body pos="0 0 0.2">
                <joint type="hinge" axis="0 1 0" stiffness="2" damping="0.1"/>
                <geom type="capsule" size="0.03 0.25" rgba=".3 .7 .9 1"/>
            </body>
        </body>
        <body pos="4 3 0">
            <geom type="cylinder" size="0.04 0.2" rgba=".5 .5 .5 1"/>
            <body pos="0 0 0.2">
                <joint type="hinge" axis="0 1 0" stiffness="2" damping="1.0"/>
                <geom type="capsule" size="0.03 0.25" rgba=".1 .1 .8 1"/>
            </body>
        </body>

        <!-- 标签: damping 0.001 / 0.02 / 0.1 / 1.0 -->
        <site pos="1 3 0.7" type="sphere" size="0.03" rgba="1 1 1 .5"/>
        <site pos="2 3 0.7" type="sphere" size="0.03" rgba="1 1 1 .5"/>
        <site pos="3 3 0.7" type="sphere" size="0.03" rgba="1 1 1 .5"/>
        <site pos="4 3 0.7" type="sphere" size="0.03" rgba="1 1 1 .5"/>

        <!-- frictionloss对比 -->
        <body pos="-2 -1 0">
            <geom type="cylinder" size="0.04 0.2" rgba=".5 .5 .5 1"/>
            <body pos="0 0 0.2">
                <joint type="hinge" axis="0 1 0" frictionloss="0" stiffness="0.5"/>
                <geom type="capsule" size="0.03 0.25" rgba=".9 .5 .9 1"/>
            </body>
        </body>
        <body pos="-1 -1 0">
            <geom type="cylinder" size="0.04 0.2" rgba=".5 .5 .5 1"/>
            <body pos="0 0 0.2">
                <joint type="hinge" axis="0 1 0" frictionloss="0.05" stiffness="0.5"/>
                <geom type="capsule" size="0.03 0.25" rgba=".7 .3 .7 1"/>
            </body>
        </body>
        <body pos="0 -1 0">
            <geom type="cylinder" size="0.04 0.2" rgba=".5 .5 .5 1"/>
            <body pos="0 0 0.2">
                <joint type="hinge" axis="0 1 0" frictionloss="0.2" stiffness="0.5"/>
                <geom type="capsule" size="0.03 0.25" rgba=".5 .1 .5 1"/>
            </body>
        </body>
    </worldbody>
</mujoco>
