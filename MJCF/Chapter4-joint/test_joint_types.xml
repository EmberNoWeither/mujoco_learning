<!-- 四种关节类型对比: free / ball / slide / hinge -->
<mujoco model="joint_types">
    <compiler angle="radian" autolimits="true"/>
    <option timestep="0.002" gravity="0 0 -9.81"/>

    <visual>
        <global realtime="1"/>
        <quality shadowsize="1024"/>
        <headlight diffuse="1 1 1" specular="0.5 0.5 0.5" active="1"/>
    </visual>

    <asset>
        <texture name="grid" type="2d" builtin="checker" width="512" height="512"
                 rgb1=".15 .15 .15" rgb2=".7 .7 .7"/>
        <material name="grid" texture="grid"/>
    </asset>

    <worldbody>
        <geom name="floor" type="plane" size="20 20 .01" material="grid" condim="3"/>

        <!-- freejoint: 完全自由运动 -->
        <body pos="-3 3 1.5">
            <freejoint/>
            <geom type="box" size="0.15 0.15 0.15" rgba=".9 .2 .2 1"/>
            <site type="sphere" size="0.04" rgba="1 1 1 .5" pos="0 0 0.5"/>
        </body>

        <!-- ball: 球形关节，固定在地面的柱子上方 -->
        <body pos="-1 3 0">
            <geom type="cylinder" size="0.05 0.4" rgba=".4 .4 .4 1"/>
            <body pos="0 0 0.4">
                <joint type="ball" pos="0 0 0"/>
                <geom type="capsule" size="0.04 0.3" rgba=".2 .8 .2 1"/>
                <geom type="sphere" size="0.06" rgba=".1 .6 .1 1" pos="0 0 0.3"/>
            </body>
        </body>

        <!-- slide: 滑轨关节，沿Y轴上下滑动 -->
        <body pos="1 3 0">
            <geom type="cylinder" size="0.05 0.6" rgba=".4 .4 .4 1"/>
            <!-- 滑轨槽（纯视觉） -->
            <site type="box" size="0.03 0.03 0.5" rgba=".3 .3 .3 .3"/>
            <body pos="0 0 0.3">
                <joint type="slide" pos="0 0 0" axis="0 0 1" range="-0.3 0.3"/>
                <geom type="box" size="0.1 0.1 0.08" rgba=".2 .2 .9 1"/>
            </body>
        </body>

        <!-- hinge: 旋转关节，绕Y轴旋转 -->
        <body pos="3 3 0">
            <geom type="cylinder" size="0.05 0.4" rgba=".4 .4 .4 1"/>
            <body pos="0 0 0.4">
                <joint type="hinge" pos="0 0 0" axis="0 1 0" range="-1.5 1.5"/>
                <geom type="capsule" size="0.04 0.3" rgba=".9 .7 .2 1"/>
                <geom type="sphere" size="0.06" rgba=".7 .5 .1 1" pos="0 0 0.3"/>
            </body>
        </body>

        <!-- 四关节对比: 相同父body下观察不同关节的运动差异 -->
        <!-- ball 连接水平旋转臂 -->
        <body pos="-2 -1 0.1">
            <geom type="cylinder" size="0.04 0.15" rgba=".6 .6 .6 1"/>
            <body pos="0 0 0.15">
                <joint type="ball"/>
                <geom type="box" size="0.25 0.04 0.02" rgba=".9 .3 .3 1"/>
            </body>
        </body>
        <!-- hinge 连接水平旋转臂 -->
        <body pos="-0.7 -1 0.1">
            <geom type="cylinder" size="0.04 0.15" rgba=".6 .6 .6 1"/>
            <body pos="0 0 0.15">
                <joint type="hinge" axis="0 0 1"/>
                <geom type="box" size="0.25 0.04 0.02" rgba=".3 .9 .3 1"/>
            </body>
        </body>
        <!-- slide 水平滑动块 -->
        <body pos="0.7 -1 0.15">
            <geom type="box" size="0.3 0.04 0.02" rgba=".6 .6 .6 1"/>
            <body pos="-0.2 0 0.05">
                <joint type="slide" axis="1 0 0" range="-0.2 0.2"/>
                <geom type="box" size="0.06 0.08 0.04" rgba=".3 .3 .9 1"/>
            </body>
        </body>
    </worldbody>
</mujoco>
